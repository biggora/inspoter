# Dedicated local test environment. All values are synthetic and test-only.
# Optional local overrides belong in .env.test.local (ignored by git).

NODE_ENV=test
DATABASE_URL="postgresql://inspoter_test:local_test_only@127.0.0.1:3833/inspoter_e2e_test?schema=public"

# Destructive test reset requires both explicit markers.
ALLOW_TEST_DB_RESET=1
TEST_DATABASE_MARKER=inspoter-e2e

# Application defaults used by unit/integration/e2e test processes.
LIST_PAGE_SIZE=50
WEBHOOK_RATE_LIMIT=120
WEBHOOK_RATE_WINDOW_MS=60000
WEBHOOK_MAX_BODY_BYTES=65536
OPERATOR_USERNAME=test-operator
OPERATOR_PASSWORD=local-test-only-password

# Provider credentials are intentionally omitted. Tests run providers in mock
# mode unless a separate, explicitly authorized real-provider profile is used.
