// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Origin: the 13-entity Slice-0 baseline was authored verbatim from
// docs/architecture.md v1.1 §2.3 in one initial migration (Decision P-1).
// P-1 revision (2026-07-18): approved feature slices legitimately extend this
// schema with reviewed, hand-authored follow-on migrations (workspaces, Q-13
// ownership, provider credentials, services, external identity, and the
// 20260718130000_mail_client_multi_account mail cluster). What remains
// prohibited is unreviewed ad-hoc incremental modeling — see
// docs/architecture.md §4.1 / docs/plan.md §4.1.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth (FR-AUTH-001) ---
enum WorkspaceRole {
  OWNER
  MEMBER
}

model Operator {
  id                 String             @id @default(cuid())
  username           String             @unique
  passwordHash       String? // scrypt hash; never returned (NFR-SEC-002). Null for Authentik-only accounts (no password set).
  email              String? // last-seen email claim from an external identity provider; display-only, never unique (an IdP email can change/be reused)
  createdAt          DateTime           @default(now())
  sessions           Session[]
  memberships        WorkspaceMember[]
  externalIdentities ExternalIdentity[]
}

// --- Third-party auth (Authentik OIDC, first of possibly several IdPs) ---
enum ExternalIdentityProvider {
  AUTHENTIK
}

model ExternalIdentity {
  id          String                   @id @default(cuid())
  provider    ExternalIdentityProvider
  subject     String // OIDC `sub` claim — the actual linking key (never email)
  operatorId  String
  operator    Operator                 @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  email       String? // last-seen `email` claim; display/debug only, never used to match identity
  lastLoginAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([provider, subject])
  @@index([operatorId])
}

model Session {
  id                        String           @id // opaque random token (the cookie value)
  operatorId                String
  operator                  Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  activeWorkspaceId         String?
  activeWorkspaceOperatorId String?
  activeMembership          WorkspaceMember? @relation("ActiveWorkspaceMembership", fields: [activeWorkspaceId, activeWorkspaceOperatorId], references: [workspaceId, operatorId], onDelete: SetNull)
  expiresAt                 DateTime
  createdAt                 DateTime         @default(now())

  @@index([expiresAt])
}

// --- Workspaces ---
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           WorkspaceMember[]
  categories        Category[]
  bookmarks         Bookmark[]
  messageCategories MessageCategory[]
  channels          Channel[]
  messages          Message[]
  mailAccounts      MailAccount[]
  mailFolders       MailFolder[]
  mailItems         MailItem[]
  logEntries        LogEntry[]
  alertCategories   AlertCategory[]
  alerts            Alert[]
  webhookTokens     WebhookToken[]
  idempotencyKeys   IdempotencyKey[]
  providerBindings  ProviderResourceBinding[]
  credentials       ProviderCredential[]
  services          Service[]
  serviceChecks     ServiceCheck[]
}

model WorkspaceMember {
  id             String        @id @default(cuid())
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  operatorId     String
  operator       Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  role           WorkspaceRole
  joinedAt       DateTime      @default(now())
  activeSessions Session[]     @relation("ActiveWorkspaceMembership")

  @@unique([workspaceId, operatorId])
  @@index([operatorId])
}

// --- Bookmarks (FR-BM-001..003, Slice 1) ---
model Category {
  id                        String     @id @default(cuid())
  workspaceId               String
  workspace                 Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                      String
  position                  Int        @default(0)
  bookmarks                 Bookmark[]
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  parentCategoryId          String?
  parentCategoryWorkspaceId String?
  parentCategory            Category?  @relation("CategoryParent", fields: [parentCategoryId, parentCategoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  childCategories           Category[] @relation("CategoryParent")

  @@unique([id, workspaceId])
  @@index([workspaceId, position, id])
  @@index([workspaceId, parentCategoryId, position, id])
}

model Bookmark {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  categoryId          String
  categoryWorkspaceId String
  category            Category  @relation(fields: [categoryId, categoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade) // AC-BM-004 cascade
  name                String
  url                 String
  icon                String? // reference value (A-2 / OQ-8): emoji | icon-name | URL
  color               String? // optional accent tone token: primary | accent | secondary (AC-BM-015..018)
  description         String?
  position            Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([workspaceId, categoryId, position, id]) // grouped display AC-BM-012
}

// --- Messages (FR-MSG-001..002) ---
model MessageCategory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  channels    Channel[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt, id])
}

model Channel {
  id                         String          @id @default(cuid())
  workspaceId                String
  workspace                  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messageCategoryId          String
  messageCategoryWorkspaceId String
  messageCategory            MessageCategory @relation(fields: [messageCategoryId, messageCategoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade) // AC-MSG-003
  name                       String
  messages                   Message[]
  webhookTokens              WebhookToken[]
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  @@unique([id, workspaceId])
  @@index([workspaceId, messageCategoryId, createdAt, id])
}

enum MessageOrigin {
  LEGACY
  OPERATOR
  WEBHOOK
}

model Message {
  id                 String        @id @default(cuid())
  workspaceId        String
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelId          String
  channelWorkspaceId String
  channel            Channel       @relation(fields: [channelId, channelWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  content            String
  author             String? // source label from webhook payload
  origin             MessageOrigin @default(LEGACY)
  createdAt          DateTime      @default(now())

  @@index([workspaceId, channelId, createdAt, id]) // NFR-PERF-001 keyset pagination (id tiebreaker for equal createdAt) + AC-MSG-004 chronological
}

// --- Mail (FR-MAIL-001..002; multi-account mail client) ---
enum MailAccountKind {
  WEBHOOK
  IMAP
}

enum MailSecurity {
  SSL
  STARTTLS
}

enum MailSyncStatus {
  IDLE
  SYNCING
  ERROR
}

enum MailSpecialUse {
  INBOX
  SENT
  DRAFTS
  TRASH
  JUNK
  ARCHIVE
  OTHER
}

model MailAccount {
  id                  String          @id @default(cuid())
  workspaceId         String
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kind                MailAccountKind
  mode                ProviderMode
  name                String
  email               String
  imapHost            String?
  imapPort            Int?
  imapSecurity        MailSecurity?
  smtpHost            String?
  smtpPort            Int?
  smtpSecurity        MailSecurity?
  username            String?
  encryptedData       String? // AES-256-GCM password payload (same scheme as ProviderCredential)
  iv                  String?
  authTag             String?
  maskedHint          String?
  isValid             Boolean?
  lastCheckedAt       DateTime?
  isActive            Boolean         @default(true)
  syncStatus          MailSyncStatus  @default(IDLE)
  syncError           String?
  lastSyncAt          DateTime?
  nextSyncAt          DateTime?
  syncLeaseExpiresAt  DateTime?
  syncIntervalSeconds Int             @default(300)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  folders             MailFolder[]
  mailItems           MailItem[]

  // At most one WEBHOOK account per workspace: raw partial unique index in the
  // migration SQL (WHERE "kind" = 'WEBHOOK') — not expressible in Prisma DSL.
  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([isActive, nextSyncAt]) // scheduler due-query; intentionally NOT workspace-prefixed (cross-tenant sweep)
}

model MailFolder {
  id                 String         @id @default(cuid())
  workspaceId        String
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId          String
  accountWorkspaceId String
  account            MailAccount    @relation(fields: [accountId, accountWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  path               String
  name               String
  delimiter          String?
  specialUse         MailSpecialUse @default(OTHER)
  position           Int            @default(0)
  uidValidity        BigInt?
  lastSeenUid        BigInt?
  lastSyncAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  mailItems          MailItem[]

  @@unique([id, workspaceId])
  @@unique([accountId, path])
  @@index([workspaceId])
}

model MailItem {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId          String
  accountWorkspaceId String
  account            MailAccount      @relation(fields: [accountId, accountWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  folderId           String
  folderWorkspaceId  String
  folder             MailFolder       @relation(fields: [folderId, folderWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  uid                BigInt? // IMAP UID; null for webhook-ingested items
  messageId          String?
  fromAddress        String
  fromName           String?
  toRecipients       Json?
  ccRecipients       Json?
  bccRecipients      Json?
  replyToAddress     String?
  subject            String
  bodyText           String
  bodyHtml           String?
  snippet            String?
  isRead             Boolean          @default(false)
  isAnswered         Boolean          @default(false)
  isFlagged          Boolean          @default(false)
  hasAttachments     Boolean          @default(false)
  receivedAt         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  attachments        MailAttachment[]

  @@unique([folderId, uid]) // idempotent sync upsert; NULL uid (webhook items) never conflicts
  @@index([workspaceId])
  @@index([workspaceId, receivedAt, id]) // sort + keyset pagination (AC-MAIL-004/005)
  @@index([workspaceId, fromAddress]) // equality filter (AC-MAIL-003, NFR-PERF-002)
  @@index([workspaceId, accountId, folderId, receivedAt, id]) // per-folder list + keyset pagination
  @@index([workspaceId, accountId, folderId, isRead]) // unread filter + folder badge counts
}

model MailAttachment {
  id          String    @id @default(cuid())
  mailItemId  String
  mailItem    MailItem  @relation(fields: [mailItemId], references: [id], onDelete: Cascade)
  partId      String? // IMAP BODYSTRUCTURE part id; null for non-IMAP sources
  filename    String
  contentType String
  sizeBytes   Int
  contentId   String?
  isInline    Boolean   @default(false)
  content     Bytes? // lazily fetched from IMAP on first access, then cached
  fetchedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([mailItemId])
}

// --- Logs (FR-LOG-001..002) ---
model LogEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  level       String // e.g. info|warn|error (validated by zod, stored as string)
  source      String
  message     String
  timestamp   DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, timestamp, id]) // sort + keyset pagination (AC-LOG-003/004)
  @@index([workspaceId, level, timestamp, id]) // equality filter (AC-LOG-002)
  @@index([workspaceId, source, timestamp, id]) // equality filter (AC-LOG-002)
}

// --- Alerts (FR-ALR-001..003) ---
model AlertCategory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  alerts      Alert[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, workspaceId])
  @@unique([workspaceId, name])
}

model Alert {
  id                       String         @id @default(cuid())
  workspaceId              String
  workspace                Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  alertCategoryId          String?
  alertCategoryWorkspaceId String?
  alertCategory            AlertCategory? @relation(fields: [alertCategoryId, alertCategoryWorkspaceId], references: [id, workspaceId], onDelete: SetNull) // D-12: reassign to uncategorized, no orphan (AC-ALR-002)
  severity                 String
  source                   String
  message                  String
  timestamp                DateTime       @default(now())
  createdAt                DateTime       @default(now())

  @@index([workspaceId, timestamp, id]) // sort + keyset pagination (AC-ALR-005/006)
  @@index([workspaceId, alertCategoryId, timestamp, id]) // filter by category (AC-ALR-004)
  @@index([workspaceId, severity, timestamp, id]) // filter by severity (AC-ALR-004)
  @@index([workspaceId, source, timestamp, id]) // filter by source (AC-ALR-004)
}

// --- Services (uptime monitoring) ---
enum MonitorType {
  HTTP
  TCP
  PING
}

enum ServiceStatus {
  PENDING
  UP
  DOWN
}

model Service {
  id                  String         @id @default(cuid())
  workspaceId         String
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  monitorType         MonitorType
  url                 String? // HTTP(S)
  host                String? // TCP, PING
  port                Int? // TCP required; PING optional (default 80 at check time)
  expectedStatusCodes String? // HTTP only, e.g. "200-299"
  intervalSeconds     Int            @default(60)
  timeoutMs           Int            @default(5000)
  retries             Int            @default(1) // consecutive failures before flipping to DOWN
  isActive            Boolean        @default(true)
  currentStatus       ServiceStatus  @default(PENDING)
  consecutiveFailures Int            @default(0)
  lastCheckedAt       DateTime?
  lastResponseTimeMs  Int?
  lastMessage         String?
  nextCheckAt         DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  checks              ServiceCheck[]

  @@unique([id, workspaceId])
  @@index([workspaceId, name])
  @@index([isActive, nextCheckAt]) // scheduler due-query; intentionally NOT workspace-prefixed (cross-tenant sweep)
}

model ServiceCheck {
  id                 String        @id @default(cuid())
  workspaceId        String
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  serviceId          String
  serviceWorkspaceId String
  service            Service       @relation(fields: [serviceId, serviceWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  status             ServiceStatus // UP | DOWN, never PENDING
  responseTimeMs     Int?
  message            String?
  checkedAt          DateTime      @default(now())
  createdAt          DateTime      @default(now())

  @@index([workspaceId, serviceId, checkedAt, id]) // keyset pagination, mirrors LogEntry/Alert style
}

// --- Webhook (FR-WH-001..002) ---
model WebhookToken {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelId          String?
  channelWorkspaceId String?
  channel            Channel?         @relation(fields: [channelId, channelWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  name               String
  tokenHash          String           @unique // sha256 of secret; raw secret shown once (AC-WH-008), never stored
  tokenPrefix        String // first chars, for UI identification only
  createdAt          DateTime         @default(now())
  revokedAt          DateTime? // AC-WH-009 revoke -> 401
  lastUsedAt         DateTime?
  idempotencyKeys    IdempotencyKey[]

  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([workspaceId, channelId, createdAt, id])
}

model IdempotencyKey {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenId          String
  tokenWorkspaceId String
  token            WebhookToken @relation(fields: [tokenId, tokenWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  key              String // client-supplied Idempotency-Key
  targetType       String // mail | message | log | alert
  targetId         String // id of the created entry, returned on replay
  createdAt        DateTime     @default(now())

  @@unique([tokenId, key]) // AC-WH-004 per-token scoping; DB uniqueness = race-safe dedup
  @@index([workspaceId, tokenId, key])
}

// --- Provider resource bindings (Q-13) ---
enum ProviderResourceType {
  DOMAIN
  SERVER
}

enum ProviderMode {
  MOCK
  REAL
}

enum ProviderOperationState {
  IDLE
  RUNNING
  RECONCILE_REQUIRED
}

model ProviderResourceBinding {
  id                      String                 @id @default(cuid())
  workspaceId             String
  workspace               Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  provider                String
  accountKey              String
  resourceType            ProviderResourceType
  mode                    ProviderMode
  remoteId                String
  displayName             String
  operationState          ProviderOperationState @default(IDLE)
  operationId             String?                @unique
  operationKind           String?
  operationIntent         Json?
  operationStartedAt      DateTime?
  operationLeaseExpiresAt DateTime?
  lastReconciledAt        DateTime?
  version                 Int                    @default(1)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@unique([id, workspaceId])
  @@unique([provider, accountKey, resourceType, mode, remoteId])
  @@index([workspaceId, resourceType, provider, mode])
  @@index([operationState, operationLeaseExpiresAt])
}

// --- Provider credentials (encrypted, workspace-scoped) ---
enum ProviderType {
  CLOUDFLARE_DNS
  HETZNER_DNS
  HETZNER_CLOUD
  GODADDY_DNS
}

model ProviderCredential {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider      ProviderType
  label         String
  encryptedData String
  iv            String
  authTag       String
  maskedHint    String
  isValid       Boolean?
  lastCheckedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId, provider])
  @@index([workspaceId])
}
