// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Schema authored verbatim from docs/architecture.md v1.1 §2.3 (Decision P-1:
// full 13-entity schema in one Slice-0 migration). Do not add per-slice
// incremental models here — see architecture.md §2.3 / plan.md §4.1.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth (FR-AUTH-001) ---
enum WorkspaceRole {
  OWNER
  MEMBER
}

model Operator {
  id           String            @id @default(cuid())
  username     String            @unique
  passwordHash String // scrypt hash; never returned (NFR-SEC-002)
  createdAt    DateTime          @default(now())
  sessions     Session[]
  memberships  WorkspaceMember[]
}

model Session {
  id                        String           @id // opaque random token (the cookie value)
  operatorId                String
  operator                  Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  activeWorkspaceId         String?
  activeWorkspaceOperatorId String?
  activeMembership          WorkspaceMember? @relation("ActiveWorkspaceMembership", fields: [activeWorkspaceId, activeWorkspaceOperatorId], references: [workspaceId, operatorId], onDelete: SetNull)
  expiresAt                 DateTime
  createdAt                 DateTime         @default(now())

  @@index([expiresAt])
}

// --- Workspaces ---
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           WorkspaceMember[]
  categories        Category[]
  bookmarks         Bookmark[]
  messageCategories MessageCategory[]
  channels          Channel[]
  messages          Message[]
  mailItems         MailItem[]
  logEntries        LogEntry[]
  alertCategories   AlertCategory[]
  alerts            Alert[]
  webhookTokens     WebhookToken[]
  idempotencyKeys   IdempotencyKey[]
  providerBindings  ProviderResourceBinding[]
  credentials       ProviderCredential[]
  services          Service[]
  serviceChecks     ServiceCheck[]
}

model WorkspaceMember {
  id             String        @id @default(cuid())
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  operatorId     String
  operator       Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  role           WorkspaceRole
  joinedAt       DateTime      @default(now())
  activeSessions Session[]     @relation("ActiveWorkspaceMembership")

  @@unique([workspaceId, operatorId])
  @@index([operatorId])
}

// --- Bookmarks (FR-BM-001..003, Slice 1) ---
model Category {
  id                        String     @id @default(cuid())
  workspaceId               String
  workspace                 Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                      String
  position                  Int        @default(0)
  bookmarks                 Bookmark[]
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  parentCategoryId          String?
  parentCategoryWorkspaceId String?
  parentCategory            Category?  @relation("CategoryParent", fields: [parentCategoryId, parentCategoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  childCategories           Category[] @relation("CategoryParent")

  @@unique([id, workspaceId])
  @@index([workspaceId, position, id])
  @@index([workspaceId, parentCategoryId, position, id])
}

model Bookmark {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  categoryId          String
  categoryWorkspaceId String
  category            Category  @relation(fields: [categoryId, categoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade) // AC-BM-004 cascade
  name                String
  url                 String
  icon                String? // reference value (A-2 / OQ-8): emoji | icon-name | URL
  color               String? // optional accent tone token: primary | accent | secondary (AC-BM-015..018)
  description         String?
  position            Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([workspaceId, categoryId, position, id]) // grouped display AC-BM-012
}

// --- Messages (FR-MSG-001..002) ---
model MessageCategory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  channels    Channel[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, workspaceId])
  @@index([workspaceId, createdAt, id])
}

model Channel {
  id                         String          @id @default(cuid())
  workspaceId                String
  workspace                  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messageCategoryId          String
  messageCategoryWorkspaceId String
  messageCategory            MessageCategory @relation(fields: [messageCategoryId, messageCategoryWorkspaceId], references: [id, workspaceId], onDelete: Cascade) // AC-MSG-003
  name                       String
  messages                   Message[]
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  @@unique([id, workspaceId])
  @@index([workspaceId, messageCategoryId, createdAt, id])
}

model Message {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelId          String
  channelWorkspaceId String
  channel            Channel   @relation(fields: [channelId, channelWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  content            String
  author             String? // source label from webhook payload
  createdAt          DateTime  @default(now())

  @@index([workspaceId, channelId, createdAt, id]) // NFR-PERF-001 keyset pagination (id tiebreaker for equal createdAt) + AC-MSG-004 chronological
}

// --- Mail (FR-MAIL-001..002) ---
model MailItem {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender      String
  subject     String
  body        String
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, receivedAt, id]) // sort + keyset pagination (AC-MAIL-004/005)
  @@index([workspaceId, sender]) // equality filter (AC-MAIL-003, NFR-PERF-002)
}

// --- Logs (FR-LOG-001..002) ---
model LogEntry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  level       String // e.g. info|warn|error (validated by zod, stored as string)
  source      String
  message     String
  timestamp   DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, timestamp, id]) // sort + keyset pagination (AC-LOG-003/004)
  @@index([workspaceId, level, timestamp, id]) // equality filter (AC-LOG-002)
  @@index([workspaceId, source, timestamp, id]) // equality filter (AC-LOG-002)
}

// --- Alerts (FR-ALR-001..003) ---
model AlertCategory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  alerts      Alert[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([id, workspaceId])
  @@unique([workspaceId, name])
}

model Alert {
  id                       String         @id @default(cuid())
  workspaceId              String
  workspace                Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  alertCategoryId          String?
  alertCategoryWorkspaceId String?
  alertCategory            AlertCategory? @relation(fields: [alertCategoryId, alertCategoryWorkspaceId], references: [id, workspaceId], onDelete: SetNull) // D-12: reassign to uncategorized, no orphan (AC-ALR-002)
  severity                 String
  source                   String
  message                  String
  timestamp                DateTime       @default(now())
  createdAt                DateTime       @default(now())

  @@index([workspaceId, timestamp, id]) // sort + keyset pagination (AC-ALR-005/006)
  @@index([workspaceId, alertCategoryId, timestamp, id]) // filter by category (AC-ALR-004)
  @@index([workspaceId, severity, timestamp, id]) // filter by severity (AC-ALR-004)
  @@index([workspaceId, source, timestamp, id]) // filter by source (AC-ALR-004)
}

// --- Services (uptime monitoring) ---
enum MonitorType {
  HTTP
  TCP
  PING
}

enum ServiceStatus {
  PENDING
  UP
  DOWN
}

model Service {
  id                  String         @id @default(cuid())
  workspaceId         String
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  monitorType         MonitorType
  url                 String? // HTTP(S)
  host                String? // TCP, PING
  port                Int? // TCP required; PING optional (default 80 at check time)
  expectedStatusCodes String? // HTTP only, e.g. "200-299"
  intervalSeconds     Int            @default(60)
  timeoutMs           Int            @default(5000)
  retries             Int            @default(1) // consecutive failures before flipping to DOWN
  isActive            Boolean        @default(true)
  currentStatus       ServiceStatus  @default(PENDING)
  consecutiveFailures Int            @default(0)
  lastCheckedAt       DateTime?
  lastResponseTimeMs  Int?
  lastMessage         String?
  nextCheckAt         DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  checks              ServiceCheck[]

  @@unique([id, workspaceId])
  @@index([workspaceId, name])
  @@index([isActive, nextCheckAt]) // scheduler due-query; intentionally NOT workspace-prefixed (cross-tenant sweep)
}

model ServiceCheck {
  id                 String        @id @default(cuid())
  workspaceId        String
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  serviceId          String
  serviceWorkspaceId String
  service            Service       @relation(fields: [serviceId, serviceWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  status             ServiceStatus // UP | DOWN, never PENDING
  responseTimeMs     Int?
  message            String?
  checkedAt          DateTime      @default(now())
  createdAt          DateTime      @default(now())

  @@index([workspaceId, serviceId, checkedAt, id]) // keyset pagination, mirrors LogEntry/Alert style
}

// --- Webhook (FR-WH-001..002) ---
model WebhookToken {
  id              String           @id @default(cuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  tokenHash       String           @unique // sha256 of secret; raw secret shown once (AC-WH-008), never stored
  tokenPrefix     String // first chars, for UI identification only
  createdAt       DateTime         @default(now())
  revokedAt       DateTime? // AC-WH-009 revoke -> 401
  lastUsedAt      DateTime?
  idempotencyKeys IdempotencyKey[]

  @@unique([id, workspaceId])
  @@index([workspaceId])
}

model IdempotencyKey {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenId          String
  tokenWorkspaceId String
  token            WebhookToken @relation(fields: [tokenId, tokenWorkspaceId], references: [id, workspaceId], onDelete: Cascade)
  key              String // client-supplied Idempotency-Key
  targetType       String // mail | message | log | alert
  targetId         String // id of the created entry, returned on replay
  createdAt        DateTime     @default(now())

  @@unique([tokenId, key]) // AC-WH-004 per-token scoping; DB uniqueness = race-safe dedup
  @@index([workspaceId, tokenId, key])
}

// --- Provider resource bindings (Q-13) ---
enum ProviderResourceType {
  DOMAIN
  SERVER
}

enum ProviderMode {
  MOCK
  REAL
}

enum ProviderOperationState {
  IDLE
  RUNNING
  RECONCILE_REQUIRED
}

model ProviderResourceBinding {
  id                      String                 @id @default(cuid())
  workspaceId             String
  workspace               Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  provider                String
  accountKey              String
  resourceType            ProviderResourceType
  mode                    ProviderMode
  remoteId                String
  displayName             String
  operationState          ProviderOperationState @default(IDLE)
  operationId             String?                @unique
  operationKind           String?
  operationIntent         Json?
  operationStartedAt      DateTime?
  operationLeaseExpiresAt DateTime?
  lastReconciledAt        DateTime?
  version                 Int                    @default(1)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@unique([id, workspaceId])
  @@unique([provider, accountKey, resourceType, mode, remoteId])
  @@index([workspaceId, resourceType, provider, mode])
  @@index([operationState, operationLeaseExpiresAt])
}

// --- Provider credentials (encrypted, workspace-scoped) ---
enum ProviderType {
  CLOUDFLARE_DNS
  HETZNER_DNS
  HETZNER_CLOUD
  GODADDY_DNS
}

model ProviderCredential {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider      ProviderType
  label         String
  encryptedData String
  iv            String
  authTag       String
  maskedHint    String
  isValid       Boolean?
  lastCheckedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}
