{
  "name": "inspoter",
  "version": "0.3.3",
  "private": true,
  "description": "Inspoter is a self-hosted dashboard for domains, DNS, servers, hosting, uptime monitoring, mail, webhooks, logs, alerts, and team workspaces.",
  "keywords": [
    "self-hosted",
    "infrastructure-dashboard",
    "devops",
    "nextjs",
    "typescript",
    "postgresql",
    "prisma",
    "dns-management",
    "server-management",
    "uptime-monitoring",
    "webhooks",
    "mail-client"
  ],
  "scripts": {
    "swagger-ui:assets": "node scripts/prepare-swagger-ui-assets.mjs",
    "predev": "pnpm run swagger-ui:assets",
    "dev": "next dev --turbopack -p 3800",
    "prebuild": "pnpm run swagger-ui:assets",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint && node scripts/check-native-controls.mjs",
    "check:ui-controls": "node scripts/check-native-controls.mjs",
    "mock:catalog:check": "node scripts/mock-provider-catalog.mjs check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,e2e,tests,scripts,prisma}/**/*.{ts,tsx,js,jsx,mjs,json,md}\" \"*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"{src,e2e,tests,scripts,prisma}/**/*.{ts,tsx,js,jsx,mjs,json,md}\" \"*.{ts,js,mjs,json,md}\"",
    "kill:app": "kill-app.cmd",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e:raw": "playwright test",
    "test:e2e": "node scripts/ci-profile.mjs e2e",
    "test:ci": "node scripts/ci-profile.mjs full",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:demo": "node prisma/seed-demo.ts",
    "test:db:guard": "node scripts/test-db.mjs guard",
    "test:db:up": "node scripts/test-db.mjs up",
    "test:db:reset": "node scripts/test-db.mjs reset",
    "test:db:migrate": "node scripts/test-db.mjs migrate",
    "test:db:seed": "node scripts/test-db.mjs seed",
    "test:db:prepare": "node scripts/test-db.mjs prepare",
    "test:db:down": "node scripts/test-db.mjs down"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "imapflow": "^1.4.7",
    "ipaddr.js": "^2.4.0",
    "mailparser": "^3.9.14",
    "next": "16.2.11",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sanitize-html": "^2.17.6",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "swagger-ui-react": "5.32.10",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^7.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/swagger-ui-react": "5.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prisma": "^7.9.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.12.0"
}
