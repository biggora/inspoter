# inspot-dashboard — environment contract (docs/architecture.md v1.1 §5.2)
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database (Slice 0) ---
# PostgreSQL connection string.
# - Running Prisma CLI/migrations from the host against `docker compose`'s
#   `db` service: use localhost:3832 — docker-compose.yml maps host port
#   3832 -> container port 5432 (5432 is reserved for a locally installed
#   Postgres, not this compose stack).
# - Inside docker-compose (the `app` service itself): use `db:5432` — compose
#   service-to-service traffic uses the container's own port, unaffected by
#   the host port mapping above (see docker-compose.yml's `app.environment`).
DATABASE_URL="postgresql://postgres:postgres@localhost:3832/inspot?schema=public"

# --- Pagination (Slice 0, NFR-PERF-001) ---
# Default page size for all keyset-paginated list sections (Mail/Logs/Alerts/Messages).
LIST_PAGE_SIZE=50

# --- Webhook ingest limits (Slice 0 base contract; enforced starting Slice 4) ---
# Requests allowed per token per rate-limit window (ADR-006, AQ-4 resolved default).
WEBHOOK_RATE_LIMIT=120
# Rate-limit window size, in milliseconds.
WEBHOOK_RATE_WINDOW_MS=60000
# Max accepted webhook request body size, in bytes (default 64KB).
WEBHOOK_MAX_BODY_BYTES=65536

# --- Outgoing webhooks (durable delivery queue + scheduler) ---
# All optional with defaults shown below.
# Delivery scheduler tick interval, in milliseconds.
# WEBHOOK_SCHEDULER_TICK_MS=10000
# Per-attempt HTTP timeout for an outgoing delivery, in milliseconds.
# WEBHOOK_DELIVERY_TIMEOUT_MS=10000
# Max delivery attempts before a delivery is marked FAILED.
# WEBHOOK_DELIVERY_MAX_ATTEMPTS=5
# Lease duration while a delivery is in flight, in milliseconds (guards
# against double-send across restarts).
# WEBHOOK_DELIVERY_LEASE_MS=30000
# Max deliveries claimed per scheduler tick.
# WEBHOOK_DELIVERY_BATCH=50
# NOTE: outgoing-webhook signing secrets are encrypted with the same
# CREDENTIAL_ENCRYPTION_KEY below — it must be set to configure webhooks.

# --- Operator auth (Slice 1, architecture §5.2, AQ-1 resolved) ---
# The single env-seeded operator's login username.
OPERATOR_USERNAME=
# Preferred: a pre-computed scrypt hash ("salt:hash"), used as-is — no
# plaintext secret in env. Provide exactly one of OPERATOR_PASSWORD_HASH /
# OPERATOR_PASSWORD; if both are set, OPERATOR_PASSWORD_HASH wins.
OPERATOR_PASSWORD_HASH=
# Convenience (dev only): plaintext password, hashed in memory at startup
# with a log warning recommending OPERATOR_PASSWORD_HASH instead.
# OPERATOR_PASSWORD=

# --- Authentik SSO (third-party auth — absent = disabled, password login remains available) ---
# Base OIDC issuer URL from Authentik's application/provider screen,
# e.g. https://auth.example.com/application/o/inspoter/
# AUTHENTIK_ISSUER=
# OAuth2/OIDC client ID from the Authentik provider.
# AUTHENTIK_CLIENT_ID=
# OAuth2/OIDC client secret from the Authentik provider.
# AUTHENTIK_CLIENT_SECRET=
# Exact callback URL registered in Authentik's provider "Redirect URIs" —
# must match byte-for-byte (scheme/host/port/path) per the OIDC spec.
# AUTHENTIK_REDIRECT_URI=https://dashboard.example.com/api/auth/authentik/callback

# --- Mail client (multi-account IMAP/SMTP) ---
# All optional with defaults shown below.
# Mail sync scheduler tick interval, in milliseconds.
# MAIL_SYNC_TICK_MS=30000
# Messages fetched per folder on the first sync of an account.
# MAIL_INITIAL_SYNC_LIMIT=200
# Max attachment size served/downloaded, in bytes (default 25MB).
# MAIL_MAX_ATTACHMENT_BYTES=26214400
# Outgoing messages allowed per workspace per rate-limit window.
# MAIL_SEND_RATE_LIMIT=30
# Send rate-limit window size, in milliseconds (default 1 hour).
# MAIL_SEND_RATE_WINDOW_MS=3600000
# Local Mail labels/rules exposure. Keep false until the current phase gate
# passes; disabling hides UI/routes and skips rule evaluation without data loss.
MAIL_LABELS_ENABLED=false

# --- Workspace backup / restore (/settings/backup) ---
# All optional with defaults shown below.
# Max accepted import archive size, in bytes (default 512MB). Oversized
# uploads are rejected with HTTP 413.
# BACKUP_MAX_IMPORT_BYTES=536870912
# Timeout for the single interactive export/import transaction, in
# milliseconds (default 5 minutes).
# BACKUP_IMPORT_TX_TIMEOUT_MS=300000

# --- Provider credentials ---
# Providers (Cloudflare, Hetzner DNS/Cloud, GoDaddy) are configured
# exclusively in the UI at /settings/providers — no env-var tokens.
# 32-byte hex key for encrypting provider credentials in DB; required to
# store and use provider credentials.
CREDENTIAL_ENCRYPTION_KEY=
